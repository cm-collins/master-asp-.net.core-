@page "/account/login"
@model dotnet_lessons.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Login";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <h2 class="text-center mb-4">Login</h2>
            <form method="post" class="card p-4 shadow-sm">
                <div asp-validation-summary="All" class="text-danger  mb-3"></div>
                <div class="mb-3">
                    <label asp-for="Credential.UserName" class="form-label"></label>
                    <input type="text" asp-for="Credential.UserName" class="form-control" />
                    <span asp-validation-for="Credential.UserName" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Credential.Password" class="form-label"></label>
                    <input type="password" asp-for="Credential.Password" class="form-control" />
                    <span asp-validation-for="Credential.Password" class="text-danger"></span>
                </div>
                <input type="submit" class="btn btn-primary w-100" value="Login" />
            </form>
        </div>
    </div>
</div>
